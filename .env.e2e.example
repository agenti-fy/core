# Copy to .env.e2e and fill in. Source it (`source .env.e2e`) before running
# the doctor and the e2e test.

# --- GitHub App (must be installed on the sandbox repo) ---
export GITHUB_APP_ID=
export GITHUB_APP_PRIVATE_KEY=
export GITHUB_APP_INSTALLATION_ID=
export GITHUB_USER='your-app-name[bot]'

# --- Anthropic ---
export ANTHROPIC_API_KEY=

# --- Sandbox repo for the harness to write into ---
export TEST_REPO=

# --- Coordinator + planner persona ---
export COORDINATOR_URL=http://localhost:8080
export TEST_PERSONA=orchestrator

# --- Optional ---
# Close the test issue and children after PASS. Use 'true' or '1' to enable;
# anything else (including '0', 'false') means do not clean up.
export CLEANUP=false
# Adjust if your stack is slow/fast:
# export TEST_DISPATCH_TIMEOUT_MS=120000
# export TEST_COMPLETION_TIMEOUT_MS=600000
