# Coordinator + agents both consume these. Copy to .env and fill in.
# (For the e2e harness use .env.e2e.example as a separate template.)

# ─── GitHub Apps (one per persona) ─────────────────────────────────────────
# This stack uses a SEPARATE GitHub App per persona so commits, comments, and
# reviews appear under that persona's bot identity (e.g. `agenti-fy-tinkerer
# [bot]`). The coordinator uses the global GITHUB_APP_* values below for
# read-only issue/PR polling — point it at any of the Apps (orchestrator's
# is conventional). Each agent service then overrides those globals from its
# own `<PERSONA>_GITHUB_APP_*` block.
#
# All 9 personas need their own App + installation ID + PEM. PEM newlines
# may be either real or literal `\n` — both work.

# Coordinator (read-only polling — point at any of the per-persona Apps).
GITHUB_APP_ID=12345
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=67890
GITHUB_USER=agentify-orchestrator[bot]

# Per-persona overrides. Each agent container reads the overrides as its
# `GITHUB_APP_*` env, so it commits/comments under its own identity. Repeat
# for: ORCHESTRATOR, CONDUCTOR, THEORIST, TINKERER, OPTIMIZER, GLUE, SKEPTIC,
# CRAFTER, SCRIBE.

ORCHESTRATOR_GITHUB_APP_ID=12345
ORCHESTRATOR_GITHUB_APP_INSTALLATION_ID=67890
ORCHESTRATOR_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
ORCHESTRATOR_GITHUB_USER=agentify-orchestrator[bot]

# CONDUCTOR_GITHUB_APP_ID=...
# CONDUCTOR_GITHUB_APP_INSTALLATION_ID=...
# CONDUCTOR_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...-----END RSA PRIVATE KEY-----"
# CONDUCTOR_GITHUB_USER=agentify-conductor[bot]
# ... (one block per remaining persona)

# ─── Anthropic (agent only) ────────────────────────────────────────────────
# Pick ONE of the two auth paths. Setting neither boots the agent with the
# StubClaudeAdapter (no real Claude calls).
#
# Path A — classic API key. Bills against API credits.
ANTHROPIC_API_KEY=sk-ant-...
#
# Path B — long-lived OAuth token from a Claude Max subscription. Run
#   `claude setup-token`
# on a host where you're signed in to Claude Code; paste the printed token
# below. Lasts ~1 year. The Agent SDK reads this env var directly. NOTE:
# whether Agent SDK calls via this token bill against your Max subscription
# vs. a separate API account is not officially documented — confirm with
# Anthropic before running a 24/7 fleet.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Force adapter selection. Default `auto` picks live when EITHER credential
# above is set, stub otherwise.
# CLAUDE_ADAPTER=auto|live|stub

# Hard caps for live runs. Defaults: 15min wall-clock, $5 per job.
# CLAUDE_TIMEOUT_MS=900000
# CLAUDE_COST_LIMIT_USD=5.0  # 0 disables
#
# Turn budgets — per method. Each defaults to a workload-appropriate value.
# CLAUDE_MAX_TURNS_PLAN=100          (default 100)
# CLAUDE_MAX_TURNS_IMPLEMENT=250     (default 250)
# CLAUDE_MAX_TURNS_REVIEW=60         (default 60)
# CLAUDE_MAX_TURNS_ADDRESS_REVIEW=200  (default 200)
# CLAUDE_MAX_TURNS_MERGE=50          (default 50)
#
# Global fallback — overrides all per-method defaults when set. Retained for
# backward compat; prefer per-method vars above for new deployments.
# CLAUDE_MAX_TURNS=500

# ─── Logging ───────────────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace. Both services emit JSON to
# stdout regardless. Pipe through `pino-pretty` if you want human-readable.
LOG_LEVEL=info

# ─── Coordinator tunables ──────────────────────────────────────────────────
# PORT=8080
# HOST=0.0.0.0
# DATA_DIR=/data

# Per-repo poll cadence default (operator-PATCHed values are preserved across
# discovery cycles).
# DEFAULT_POLL_INTERVAL_S=30

# How often the coordinator's loops fire.
# WORK_POLL_S=30
# JOB_COMPLETION_POLL_S=5
# INSTALLATION_REFRESH_S=300

# Job-row retention. Old failed_to_dispatch and complete/failed rows are GC'd
# hourly past these windows.
# FAILED_DISPATCH_RETENTION_DAYS=7
# COMPLETED_JOB_RETENTION_DAYS=30

# Plan-completion poller. Walks open plans, ticks parent-issue checklists,
# closes the parent when all children are closed.
# PLAN_COMPLETION_POLL_S=60

# Stale in-progress label sweeper. Issues whose `task:*-in-progress` is older
# than STALE_JOB_TIMEOUT_S (and have no active job in the DB) are restored to
# `task:<method>` so a fresh dispatch can pick them up. The sweep runs on
# STALE_JOB_SWEEP_S cadence.
# STALE_JOB_TIMEOUT_S=1800
# STALE_JOB_SWEEP_S=600

# Maximum automated review ↔ address-review cycles per PR. On the Nth re-dispatch
# (after the first review) the PR receives `needs-human` instead of a reviewer
# label. Default 5. Set higher for repos with many review passes; 0 is not valid
# (use needs-human directly to pause routing).
# PR_MAX_REVIEW_CYCLES=5

# Hard cap on the serialized job result (JSON.stringify length) before it lands
# in the jobs.result_json SQLite column. Jobs whose result exceeds this cap are
# recorded as task_error with artifacts replaced by {} to keep the row valid JSON
# for downstream consumers. Default 262144 (256 KiB). Raise if legitimate agents
# routinely produce large artifacts; lower to protect DB throughput.
# MAX_RESULT_JSON_BYTES=262144

# Disable the GitHub-driven loops + the agent's GitHub mutations. Useful for
# offline dev. Accepts: 1, true, yes, on (true) / 0, false, no, off, '' (false).
# Anything else falls back to the default below.
# DISABLE_GITHUB=false

# ─── Agent tunables ────────────────────────────────────────────────────────
# AGENT_PORT=8080  (or PORT)
# COORDINATOR_URL=http://coordinator:8080
# AGENT_PUBLIC_URL=http://orchestrator:8080
# SOUL_PATH=/etc/agentify/SOUL.md
# WORKSPACES_DIR=/workspaces

# Register-with-retry on boot.
# REGISTER_RETRY_MS=2000
# REGISTER_MAX_ATTEMPTS=60

# Heartbeat every 15s.
# HEARTBEAT_INTERVAL_MS=15000

# HTTP timeout for agent → coordinator calls.
# COORDINATOR_TIMEOUT_MS=15000

# In-memory job history cap on the agent (LRU).
# JOB_HISTORY_CAPACITY=500
