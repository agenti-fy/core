{
  "name": "@agenti-fy/setup",
  "version": "0.2.1",
  "description": "Interactive setup wizard for agenti-fy. Registers ten GitHub Apps (one coordinator + nine per-persona) via the App Manifest flow, installs them on the target repo, collects Anthropic credentials, and writes a ready-to-use .env. Run with `npx @agenti-fy/setup init`.",
  "license": "MIT",
  "author": "agenti-fy contributors",
  "homepage": "https://github.com/agenti-fy/core#readme",
  "bugs": {
    "url": "https://github.com/agenti-fy/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agenti-fy/core.git",
    "directory": "packages/setup"
  },
  "keywords": [
    "agenti-fy",
    "setup",
    "wizard",
    "github-app",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "agentify-setup": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/bin.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@agenti-fy/shared": "workspace:*",
    "@octokit/auth-app": "^7.1.1",
    "@octokit/rest": "^21.0.2",
    "undici": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2"
  }
}
