{
  "name": "@agenti-fy/shared",
  "version": "0.3.0",
  "description": "Shared schemas, label/dep parsers, and RPC types for the agenti-fy multi-agent system. Internal package; consumed by @agenti-fy/agent, @agenti-fy/coordinator, @agenti-fy/setup, and @agenti-fy/tui.",
  "license": "MIT",
  "author": "agenti-fy contributors",
  "homepage": "https://github.com/agenti-fy/core#readme",
  "bugs": {
    "url": "https://github.com/agenti-fy/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agenti-fy/core.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "agenti-fy",
    "agents",
    "shared",
    "schemas"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
